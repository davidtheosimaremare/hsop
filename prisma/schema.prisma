generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customerId           String?               @unique
  isActive             Boolean               @default(true)
  phone                String?
  username             String?               @unique
  address              String?
  otp                  String?
  otpExpiresAt         DateTime?
  isVerified           Boolean               @default(false)
  role                 String                @default("ADMIN")
  position             String?
  isPrimaryContact     Boolean               @default(false)
  Notification         Notification[]
  SalesQuotation       SalesQuotation[]
  upgradeRequests      UpgradeRequest[]
  customer             Customer?             @relation(fields: [customerId], references: [id])
  UserClient           UserClient[]
  ProfileUpdateRequest ProfileUpdateRequest?
  vendorProducts       Product[]             @relation("VendorProducts")
  stockLogs            ProductStockLog[]

  @@index([email])
  @@index([role])
}

model Customer {
  id                     String            @id @default(cuid())
  accurateId             Int?              @unique
  name                   String?
  email                  String?           @unique
  phone                  String?
  address                String?
  company                String?
  companyEmail           String?
  companyPhone           String?
  province               String?
  city                   String?
  district               String?
  postalCode             String?
  discount1              Float             @default(0)
  discount2              Float             @default(0)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  discountCP             String            @default("0")
  discountLP             String            @default("0")
  discountLighting       String            @default("0")
  businessCategory       String?
  image                  String?
  discountCPIndent       String            @default("0")
  discountLPIndent       String            @default("0")
  discountLightingIndent String            @default("0")
  accurateCustomerCode   String?
  type                   String            @default("BISNIS")
  addresses              CustomerAddress[]
  orders                 Order[]
  SalesQuotation         SalesQuotation[]
  users                  User[]

  @@index([email])
  @@index([accurateId])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  address    String
  district   String?
  city       String?
  province   String?
  postalCode String?
  recipient  String?
  phone      String?
  isPrimary  Boolean  @default(false)
  isBilling  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Product {
  id              String      @id @default(cuid())
  sku             String      @unique
  name            String
  description     String?
  longDescription String?
  price           Float
  availableToSell Int         @default(0)
  brand           String?
  category        String?
  image           String?
  sliderImages    String[]    @default([])
  accurateId      Int?        @unique
  itemType        String?
  isVisible       Boolean     @default(true)
  datasheet       String?
  specifications  Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
  vendorId        String?
  vendor          User?       @relation("VendorProducts", fields: [vendorId], references: [id])
  status          String      @default("APPROVED")
  isVendorProduct Boolean     @default(false)
  stockLogs       ProductStockLog[]

  @@index([sku])
  @@index([category])
  @@index([brand])
  @@index([status])
  @@index([vendorId])
}

model ProductStockLog {
  id          String   @id @default(cuid())
  productId   String
  vendorId    String
  oldStock    Int
  newStock    Int
  changeValue Int
  source      String   @default("MANUAL") // "EXCEL" atau "MANUAL"
  createdAt   DateTime @default(now())
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor      User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([vendorId])
}

model VendorCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryMapping {
  id           String   @id @default(cuid())
  categoryName String   @unique
  discountType String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id                String      @id @default(cuid())
  customerId        String
  status            String      @default("PENDING")
  totalAmount       Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  attachmentInvoice String?
  attachmentPO      String?
  attachmentQuote   String?
  discount          Float       @default(0)
  notes             String?
  customer          Customer    @relation(fields: [customerId], references: [id])
  items             OrderItem[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model SearchSuggestion {
  id        String   @id @default(cuid())
  term      String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([term])
}

model Category {
  id         String     @id @default(cuid())
  name       String
  alias      String?
  parentId   String?
  isVisible  Boolean    @default(true)
  order      Int        @default(0)
  accurateId Int?       @unique
  image      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")

  @@index([parentId])
}

model CategorySection {
  id          String   @id @default(cuid())
  title       String
  order       Int      @default(0)
  categoryIds String[]
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientProject {
  id          String   @id @default(cuid())
  projectName String
  clientName  String
  location    String?
  image       String
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Brand {
  id         String   @id @default(cuid())
  name       String   @unique
  alias      String?
  isVisible  Boolean  @default(true)
  accurateId Int?     @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([name])
}

model Banner {
  id        String   @id @default(cuid())
  title     String?
  image     String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  excerpt           String?
  content           String
  image             String?
  metaTitle         String?
  metaDescription   String?
  metaKeywords      String?
  ogImage           String?
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  author            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  relatedProductIds String[]

  @@index([slug])
}

model DiscountRule {
  id             String   @id @default(cuid())
  categoryGroup  String   @unique
  stockDiscount  String   @default("0")
  indentDiscount String   @default("0")
  description    String?
  updatedAt      DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@index([key])
}

model SalesQuotation {
  id                     String                   @id @default(cuid())
  quotationNo            String                   @unique
  userId                 String?
  customerId             String?
  email                  String
  phone                  String
  status                 String                   @default("PENDING")
  isEstimation           Boolean                  @default(false)
  lastSentAt             DateTime?
  sentQuotationNo        String?
  totalAmount            Float                    @default(0)
  notes                  String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  adminNotes             String?
  offeredAt              DateTime?
  processedAt            DateTime?
  processedBy            String?
  specialDiscount        Float?
  completedAt            DateTime?
  confirmedAt            DateTime?
  shippedAt              DateTime?
  shippingNotes          String?
  shippingAddress        String?
  shippingProofPath      String?
  trackingNumber         String?
  freeShipping           Boolean                  @default(false)
  shippingCost           Float?
  specialDiscountNote    String?
  specialDiscountRequest Boolean                  @default(false)
  isHsqApproved          Boolean                  @default(false)
  userPoPath             String?
  userClientId           String?
  returnEvidencePath     String?
  accurateDoId           Int?
  accurateDoNo           String?
  accurateHsoId          Int?
  accurateHsoNo          String?
  accurateHsqId          Int?
  accurateHsqNo          String?
  accurateSyncStatus     String?                  @default("PENDING")
  clientName             String?
  hdoPdfGeneratedAt      DateTime?
  hsoPdfGeneratedAt      DateTime?
  hsqPdfGeneratedAt      DateTime?
  paymentMethod          String?                  @default("CASH")
  poNotes                String?
  revisionNumber         Int                      @default(0)
  adminDoPdfPath         String?
  adminInvoicePdfPath    String?
  adminQuotePdfPath      String?
  adminSoPdfPath         String?
  paymentProofPath       String?
  receiptEvidencePath    String?
  returnRequest          Boolean                  @default(false)
  taxInvoiceUrl          String?
  returnReason           String?
  invoice                SalesInvoice?
  customer               Customer?                @relation(fields: [customerId], references: [id])
  user                   User?                    @relation(fields: [userId], references: [id])
  activities             SalesQuotationActivity[]
  items                  SalesQuotationItem[]

  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([quotationNo])
}

model SalesQuotationItem {
  id                            String                          @id @default(cuid())
  quotationId                   String
  productSku                    String
  productName                   String
  brand                         String
  quantity                      Int
  price                         Float
  basePrice                     Float?
  discountPercent               Float?
  discountAmount                Float?
  discountStr                   String?
  adminNote                     String?
  availableQty                  Int?
  isAvailable                   Boolean?
  stockStatus                   String?
  quotation                     SalesQuotation                  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  SalesQuotationItemAlternative SalesQuotationItemAlternative[]

  @@index([quotationId])
  @@index([productSku])
}

model HomeCTA {
  id                  String   @id @default(cuid())
  title               String
  subtitle            String?
  image               String?
  primaryButtonText   String?
  primaryButtonLink   String?
  secondaryButtonText String?
  secondaryButtonLink String?
  position            String   @unique
  isVisible           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WebhookLog {
  id          String    @id @default(cuid())
  source      String    @default("ACCURATE")
  event       String
  payload     Json
  status      String
  message     String?
  retryCount  Int       @default(0)
  lastRetryAt DateTime?
  processedAt DateTime  @default(now())

  @@index([status])
  @@index([source])
}

model Page {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
}

model UpgradeRequest {
  id           String   @id @default(cuid())
  userId       String
  requestType  String
  status       String   @default("PENDING")
  companyName  String?
  businessType String?
  address      String?
  phone        String?
  ktp          String?
  npwp         String?
  adminNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ktpName      String?
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model RolePermission {
  id          String   @id @default(cuid())
  updatedAt   DateTime @updatedAt
  permissions Json     @default("[]")
  role        String   @unique
}

model SalesInvoice {
  id                String         @id @default(cuid())
  quotationId       String         @unique
  accurateHsiId     Int?           @unique
  accurateHsiNo     String?        @unique
  invoiceDate       DateTime       @default(now())
  dueDate           DateTime?
  totalAmount       Float          @default(0)
  paidAmount        Float          @default(0)
  status            String         @default("UNPAID")
  reminderSentAt    DateTime?
  overdueNotifiedAt DateTime?
  pdfGeneratedAt    DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  quotation         SalesQuotation @relation(fields: [quotationId], references: [id])

  @@index([status])
}

model SalesQuotationActivity {
  id          String         @id @default(cuid())
  quotationId String
  type        String
  title       String
  description String?
  performedBy String?
  createdAt   DateTime       @default(now())
  quotation   SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model SalesReturn {
  id               String   @id @default(cuid())
  quotationId      String
  reason           String
  status           String   @default("REQUESTED")
  adminNotes       String?
  photoUrls        String?
  accurateReturnId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([quotationId])
}

model UserClient {
  id        String   @id @default(cuid())
  userId    String
  name      String
  company   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProfileUpdateRequest {
  id           String   @id @default(cuid())
  userId       String   @unique
  field        String
  newValue     String
  otp          String
  otpExpiresAt DateTime
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalesQuotationItemAlternative {
  id              String             @id @default(cuid())
  quotationItemId String
  productSku      String
  productName     String
  brand           String
  quantity        Int
  price           Float
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  quotationItem   SalesQuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@index([quotationItemId])
}

model Province {
  id        String    @id
  name      String
  regencies Regency[]
}

model Regency {
  id         String     @id
  provinceId String
  name       String
  province   Province   @relation(fields: [provinceId], references: [id])
  districts  District[]

  @@index([provinceId])
}

model District {
  id        String  @id
  regencyId String
  name      String
  regency   Regency @relation(fields: [regencyId], references: [id])

  @@index([regencyId])
}
